# ── SendGrid (Email) ──
# Sign up at https://sendgrid.com — free tier: 100 emails/day
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=you@yourdomain.com

# ── Twilio (SMS) ──
# Sign up at https://twilio.com — free trial includes $15 credit
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# ── Server ──
PORT=3001

# ── Supabase (required for scheduler) ──
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── Stripe (Billing) ──
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Plan price IDs
PRICE_STARTER_MONTHLY=price_...
PRICE_STARTER_ANNUAL=price_...
PRICE_GROWTH_MONTHLY=price_...
PRICE_GROWTH_ANNUAL=price_...
PRICE_PRO_MONTHLY=price_...
PRICE_PRO_ANNUAL=price_...

# Overage price IDs
PRICE_STARTER_EMAIL=price_...
PRICE_STARTER_SMS=price_...
PRICE_GROWTH_EMAIL=price_...
PRICE_GROWTH_SMS=price_...
PRICE_PRO_EMAIL=price_...
PRICE_PRO_SMS=price_...
